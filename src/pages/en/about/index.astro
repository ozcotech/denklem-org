---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import screen1 from '../../../assets/denklem_appstore_1.png';
import screen2 from '../../../assets/denklem_appstore_2.png';
import screen3 from '../../../assets/denklem_appstore_3.png';
import screen4 from '../../../assets/denklem_appstore_4.png';
import screen5 from '../../../assets/denklem_appstore_5.png';
import screen6 from '../../../assets/denklem_appstore_6.png';

const pageTitle = "App";
const pageDescription = "Explore the features and screens of the Denklem mobile application.";

const screens = [
  { image: screen1, alt: "Calculate Mediation Fees Instantly" },
  { image: screen2, alt: "Detailed Calculation Breakdown" },
  { image: screen3, alt: "All Calculation Methods in One Place" },
  { image: screen4, alt: "Official Legislation & Tariffs" },
  { image: screen5, alt: "Agreement & No Agreement" },
  { image: screen6, alt: "3 Languages Dark & Light Mode" },
];
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-4 text-center gradient-text">{pageTitle}</h1>
    <p class="text-center text-base-content/60 mb-12 max-w-lg mx-auto text-sm">
      Explore all features of the Denklem application.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {screens.map((screen) => (
        <div class="app-screen-card">
          <Image
            src={screen.image}
            alt={screen.alt}
            class="w-full h-auto rounded-2xl"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
