---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const pageTitle = "Announcements";
const pageDescription = "Latest news, updates and important announcements about Denklem mobile application.";

const allItems = await getCollection('announcements', ({ data }: CollectionEntry<'announcements'>) => data.lang === 'en');
const sorted = allItems.sort((a: CollectionEntry<'announcements'>, b: CollectionEntry<'announcements'>) => b.data.date.valueOf() - a.data.date.valueOf());

interface AnnouncementItem { title: string; date: string; href: string; }
const announcements: AnnouncementItem[] = sorted.map((entry: CollectionEntry<'announcements'>) => ({
  title: entry.data.title,
  date: entry.data.date.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }),
  href: `/en/announcements/${entry.id.replace('en/', '').replace(/\.mdx?$/, '')}`,
}));
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-6 text-center">{pageTitle}</h1>
    <p class="text-center mb-8 text-base-content/70">
      You can follow the latest developments and announcements about the Denklem application here.
    </p>
    <div class="space-y-6 max-w-3xl mx-auto">
      {announcements.map((item) => (
        <div class="card bg-base-200 shadow-md">
          <div class="card-body">
            <h2 class="card-title text-xl font-semibold">{item.title}</h2>
            <p class="text-sm text-base-content/70">{item.date}</p>
            <div class="card-actions justify-end mt-2">
              <a href={item.href} class="btn btn-outline border-base-content text-base-content bg-transparent rounded-xl btn-scale">
                Read More
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
