---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const pageTitle = "Blog";
const pageDescription = "Latest articles, tips and updates on mediation, legal fee calculations and the Denklem application.";

const allPosts = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => data.lang === 'en');
const sorted = allPosts.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.valueOf() - a.data.date.valueOf());

interface PostItem { entry: CollectionEntry<'blog'>; slug: string; date: string; }
const posts: PostItem[] = sorted.map((entry: CollectionEntry<'blog'>) => ({
  entry,
  slug: entry.id.replace('en/', '').replace(/\.mdx?$/, ''),
  date: entry.data.date.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }),
}));
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-6 text-center">{pageTitle}</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
      {posts.map(({ entry, slug, date }) => (
        <div class="card bg-base-200 shadow-xl">
          <div class="card-body">
            <h2 class="card-title">{entry.data.title}</h2>
            <p class="text-sm text-base-content/70">{date}</p>
            <p class="text-sm mt-1">{entry.data.description}</p>
            <div class="card-actions justify-end mt-2">
              <a href={`/en/blog/${slug}`} class="btn btn-outline border-base-content text-base-content bg-transparent rounded-xl btn-scale">
                Read More
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
