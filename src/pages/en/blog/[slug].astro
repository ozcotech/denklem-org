---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => data.lang === 'en');
  return entries.map((entry: CollectionEntry<'blog'>) => ({
    params: { slug: entry.id.replace('en/', '').replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'blog'> };
const { Content } = await entry.render();
const date = entry.data.date.toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
---
<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="container mx-auto px-4 py-12 max-w-2xl">
    <a href="/en/blog" class="text-sm text-base-content/60 hover:text-base-content mb-6 inline-block">
      ← Back to Blog
    </a>
    <h1 class="text-3xl font-bold mb-2">{entry.data.title}</h1>
    <p class="text-sm text-base-content/60 mb-8">{date}</p>
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <Content />
    </div>
  </div>
</BaseLayout>
