---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import screen1 from '../../assets/denklem_appstore_1.png';
import screen2 from '../../assets/denklem_appstore_2.png';
import screen3 from '../../assets/denklem_appstore_3.png';
import screen4 from '../../assets/denklem_appstore_4.png';
import screen5 from '../../assets/denklem_appstore_5.png';
import screen6 from '../../assets/denklem_appstore_6.png';

const pageTitle = "Uygulama";
const pageDescription = "Denklem mobil uygulamasının özelliklerini ve ekranlarını keşfedin.";

const screens = [
  { image: screen1, alt: "Anında Arabuluculuk Ücreti Hesaplama" },
  { image: screen2, alt: "Detaylı Hesaplama Dökümü" },
  { image: screen3, alt: "Tüm Hesaplama Yöntemleri Tek Yerde" },
  { image: screen4, alt: "Resmi Mevzuat ve Tarifeler" },
  { image: screen5, alt: "Anlaşma ve Anlaşmama" },
  { image: screen6, alt: "3 Dil, Koyu ve Açık Mod" },
];
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-4 text-center gradient-text">{pageTitle}</h1>
    <p class="text-center text-base-content/60 mb-12 max-w-lg mx-auto text-sm">
      Denklem uygulamasının tüm özelliklerini keşfedin.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {screens.map((screen) => (
        <div class="app-screen-card">
          <Image
            src={screen.image}
            alt={screen.alt}
            class="w-full h-auto rounded-2xl"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
