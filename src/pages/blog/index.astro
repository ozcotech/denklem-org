---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const pageTitle = "Blog";
const pageDescription = "Arabuluculuk, yasal ücret hesaplamaları ve Denklem uygulamasıyla ilgili en son makaleler, ipuçları ve güncellemeler.";

const allPosts = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => data.lang === 'tr');
const sorted = allPosts.sort((a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.date.valueOf() - a.data.date.valueOf());

interface PostItem { title: string; description: string; date: string; href: string; }
const posts: PostItem[] = sorted.map((entry: CollectionEntry<'blog'>) => ({
  title: entry.data.title,
  description: entry.data.description,
  date: entry.data.date.toLocaleDateString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric' }),
  href: `/blog/${entry.id.replace('tr/', '').replace(/\.mdx?$/, '')}`,
}));
---
<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-6 text-center">{pageTitle}</h1>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
      {posts.map((post) => (
        <div class="card bg-base-200 shadow-xl">
          <div class="card-body">
            <h2 class="card-title">{post.title}</h2>
            <p class="text-sm text-base-content/70">{post.date}</p>
            <p class="text-sm mt-1">{post.description}</p>
            <div class="card-actions justify-end mt-2">
              <a href={post.href} class="btn btn-outline border-base-content text-base-content bg-transparent rounded-xl btn-scale">
                Devamını Oku
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
