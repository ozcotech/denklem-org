---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('announcements', ({ data }: CollectionEntry<'announcements'>) => data.lang === 'tr');
  return entries.map((entry: CollectionEntry<'announcements'>) => ({
    params: { slug: entry.id.replace('tr/', '').replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'announcements'> };
const { Content } = await entry.render();
const date = entry.data.date.toLocaleDateString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric' });
---
<BaseLayout title={entry.data.title} description={entry.data.title}>
  <div class="container mx-auto px-4 py-12 max-w-2xl">
    <a href="/announcements" class="text-sm text-base-content/60 hover:text-base-content mb-6 inline-block">
      ← Duyurulara Dön
    </a>
    <h1 class="text-3xl font-bold mb-2">{entry.data.title}</h1>
    <p class="text-sm text-base-content/60 mb-8">{date}</p>
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <Content />
    </div>
    {entry.data.link && (
      <div class="mt-8">
        <a
          href={entry.data.link}
          target={entry.data.linkExternal ? '_blank' : '_self'}
          rel={entry.data.linkExternal ? 'noopener noreferrer' : undefined}
          class="btn btn-outline border-base-content text-base-content bg-transparent rounded-xl btn-scale"
        >
          {entry.data.linkText}
        </a>
      </div>
    )}
  </div>
</BaseLayout>
